{
  "name": "new-api-docs",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start",
    "start:all-locales": "npm run preview",
    "start:zh": "docusaurus start --locale zh-CN",
    "start:zh-tw": "docusaurus start --locale zh-TW",
    "start:fr": "docusaurus start --locale fr",
    "start:ja": "docusaurus start --locale ja",
    "start:ru": "docusaurus start --locale ru",
    "start:vi": "docusaurus start --locale vi",
    "preview": "docusaurus build && docusaurus serve --host 0.0.0.0",
    "build": "docusaurus build",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "admin": "cd admin-server && npm start",
    "generate:api-docs": "python3 scripts/generate-api-docs.py && python3 scripts/write_doc_pages.py",
    "setup:i18n": "python3 scripts/setup-i18n.py",
    "dev:all": "concurrently \"npm start\" \"npm run admin\""
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/react": "^19.0.0",
    "concurrently": "^9.1.2",
    "typescript": "~6.0.2"
  },
  "optionalDependencies": {
    "@easyops-cn/docusaurus-search-local": "^0.49.0"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
