    "/v1/chat/completions": {
      "post": {
        "operationId": "post_____________",
        "summary": "创建聊天创作图 （非流）",
        "tags": [
          "OpenAI 格式"
        ],
        "responses": {
          "200": {
            "description": "请求成功"
          },
          "401": {
            "description": "未授权"
          },
          "429": {
            "description": "超出速率限制"
          }
        },
        "description": "给定一个提示，该模型将返回一个或多个预测的完成，并且还可以返回每个位置的替代标记的概率。\n\n为提供的提示和参数创建完成\n\n官方文档：https://platform.openai.com/docs/api-reference/images/create",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object"
              }
            }
          }
        }
      }
    },
